# AnimaCare Root Gitignore

# Byte-compiled / optimized / DLL files
**/__pycache__/
**/*.py[cod]
**/*$py.class

# OS / Editor Files
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environments & Private Configs
.env
.env.local
.env.*.local
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Django Databases & Logs
*.sqlite3
*.sqlite3-journal
*.log
check2.log
check_err.log
error.txt
error_output.txt
error_output2.txt
migrations.txt

# Node / Frontend Build & Cache
node_modules/
dist/
dist-ssr/
.cache/
.npm/

# Documentation, Diagrams & Reports (Not required for code execution)
*.docx
*.pdf
PRD_AnimaCare.md
Testing_Report_AnimaCare.md
animacare_documentation.md

# Local Dev / Scratch Scripts (not part of the main codebase/tests)
animacare_backend/test*.py
animacare_backend/debug*.py
animacare_backend/retroactive*.py
tables.txt
error_output.txt
error_output2.txt
error.txt

